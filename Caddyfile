pingcrm.sawinyh.com {
    # API routes to backend
    handle /api/* {
        reverse_proxy backend:8000
    }
    
    # MCP Server (SSE transport — disable buffering for streaming)
    handle /mcp/* {
        reverse_proxy backend:8000 {
            flush_interval -1
        }
    }

    # WebSocket support
    handle /ws/* {
        reverse_proxy backend:8000
    }
    
    # Static avatar files from backend
    handle /static/* {
        reverse_proxy backend:8000
    }
    
    # Everything else to frontend
    handle {
        reverse_proxy frontend:3000
    }
}
