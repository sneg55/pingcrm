#!/bin/bash
# Pre-push hook: run tests for changed files before pushing.
# Install: git config core.hooksPath .githooks

set -e

echo "🧪 Running pre-push tests..."

# Get changed files vs remote
REMOTE_REF=$(git rev-parse @{upstream} 2>/dev/null || echo "HEAD~1")
CHANGED=$(git diff --name-only "$REMOTE_REF"..HEAD 2>/dev/null || git diff --name-only HEAD~1..HEAD)

RUN_BACKEND=false
RUN_FRONTEND=false
EXT_CODE_CHANGED=false
EXT_MANIFEST_CHANGED=false

for f in $CHANGED; do
  case "$f" in
    backend/*) RUN_BACKEND=true ;;
    frontend/*) RUN_FRONTEND=true ;;
    chrome-extension/manifest.json) EXT_MANIFEST_CHANGED=true ;;
    chrome-extension/*) EXT_CODE_CHANGED=true ;;
  esac
done

FAILED=false

# Extension version bump check
if $EXT_CODE_CHANGED && ! $EXT_MANIFEST_CHANGED; then
  echo ""
  echo "❌ Chrome extension files changed but manifest.json version was not bumped."
  echo "   Update \"version\" in chrome-extension/manifest.json before pushing."
  echo "   Changed extension files:"
  echo "$CHANGED" | grep "^chrome-extension/" | grep -v manifest.json | sed 's/^/     /'
  FAILED=true
fi

if $RUN_BACKEND; then
  echo ""
  echo "━━━ Backend tests (pytest) ━━━"
  cd backend
  if [ -d .venv ]; then
    source .venv/bin/activate
  fi
  if pytest -x -q 2>&1; then
    echo "✅ Backend tests passed"
  else
    echo "❌ Backend tests failed"
    FAILED=true
  fi
  cd ..
fi

if $RUN_FRONTEND; then
  echo ""
  echo "━━━ Frontend type check (tsc) ━━━"
  cd frontend
  if npx tsc --noEmit 2>&1; then
    echo "✅ TypeScript check passed"
  else
    echo "❌ TypeScript check failed"
    FAILED=true
  fi

  echo ""
  echo "━━━ Frontend lint (next lint) ━━━"
  # Mirror prod build: warnings become errors (matches `next build` behavior).
  if npx next lint --max-warnings 0 2>&1; then
    echo "✅ Lint passed"
  else
    echo "❌ Lint failed (next build will reject this)"
    FAILED=true
  fi

  echo ""
  echo "━━━ Frontend tests (vitest) ━━━"
  if npx vitest run --reporter=dot 2>&1; then
    echo "✅ Frontend tests passed"
  else
    echo "❌ Frontend tests failed"
    FAILED=true
  fi
  cd ..
fi

if ! $RUN_BACKEND && ! $RUN_FRONTEND; then
  echo "No backend/frontend changes — skipping tests."
fi

if $FAILED; then
  echo ""
  echo "❌ Push blocked: tests failed. Fix and try again."
  echo "   To skip: git push --no-verify"
  exit 1
fi

echo ""
echo "✅ All tests passed — pushing."
